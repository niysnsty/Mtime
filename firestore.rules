rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profile rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Cycles rules
    match /cycles/{cycleId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // Daily logs rules
    match /daily_logs/{logId} {
      // For daily logs, we check cycleId or just ensure they own the log if we add a userId field.
      // Assuming a userId field is present for easier security:
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
